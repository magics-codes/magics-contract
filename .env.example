# Base mainnet
BASE_RPC_URL=https://mainnet.base.org

# Base sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer key (never commit a real one)
DEPLOYER_PRIVATE_KEY=0x

# BaseScan API key — used for `forge verify-contract`
BASESCAN_API_KEY=

# Salt for CREATE2 deployments (per-environment)
DEPLOY_SALT=magics.v0.1.0
