# Cluster RPC endpoints
SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Deployer keypair path (never commit a real one)
DEPLOYER_KEYPAIR=~/.config/solana/id.json

# Anchor provider — pick a cluster: localnet | devnet | mainnet
ANCHOR_PROVIDER_CLUSTER=devnet
